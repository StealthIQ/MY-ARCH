#!/bin/bash
# LEOS Interactive Bare-Metal Installer
# Boot Arch live USB → connect to internet → run this script
# Handles: partitioning, btrfs subvolumes, pacstrap, bootloader, full system config
set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; CYAN='\033[0;36m'; YELLOW='\033[1;33m'; BOLD='\033[1m'; NC='\033[0m'
LEOS_DIR="$(cd "$(dirname "$0")/.." && pwd)"

die() { echo -e "${RED}ERROR: $1${NC}"; exit 1; }
info() { echo -e "${CYAN}:: $1${NC}"; }
warn() { echo -e "${YELLOW}:: $1${NC}"; }
ok() { echo -e "${GREEN}:: $1${NC}"; }
settle() { partprobe "$DISK" 2>/dev/null; sleep 1; udevadm settle 2>/dev/null || true; }

clear
echo -e "${BOLD}"
echo "╔══════════════════════════════════════════╗"
echo "║         LEOS Bare-Metal Installer        ║"
echo "╠══════════════════════════════════════════╣"
echo "║  AI-Optimized Arch Linux                 ║"
echo "║  Full Arch kernel + zswap + btrfs zstd   ║"
echo "╚══════════════════════════════════════════╝"
echo -e "${NC}"

[ "$EUID" -eq 0 ] || die "Run as root"
[ -d "$LEOS_DIR" ] || die "LEOS repo not found at $LEOS_DIR"
ping -c1 -W2 archlinux.org &>/dev/null || die "No internet. Connect first: iwctl / nmtui"

# ═══════════════════════════════════════════
# DISK SELECTION
# ═══════════════════════════════════════════
info "Detecting disks..."
echo ""

mapfile -t DISKS < <(lsblk -dnpo NAME -I 8,259,254 | grep -v "^$")
[ ${#DISKS[@]} -gt 0 ] || die "No disks found"

echo -e "${BOLD}Available disks:${NC}"
for i in "${!DISKS[@]}"; do
    disk="${DISKS[$i]}"
    size=$(lsblk -dno SIZE "$disk" | xargs)
    model=$(lsblk -dno MODEL "$disk" | xargs)
    echo -e "  ${GREEN}$((i+1)))${NC} $disk  ${BOLD}$size${NC}  $model"
done
echo ""

read -rp "Select disk [1-${#DISKS[@]}]: " DISK_NUM
[[ "$DISK_NUM" =~ ^[0-9]+$ ]] && [ "$DISK_NUM" -ge 1 ] && [ "$DISK_NUM" -le ${#DISKS[@]} ] || die "Invalid selection"
DISK="${DISKS[$((DISK_NUM-1))]}"

# ═══════════════════════════════════════════
# INSTALL MODE
# ═══════════════════════════════════════════
echo ""
info "Partition layout of $DISK:"
lsblk -po NAME,SIZE,FSTYPE,LABEL,MOUNTPOINT "$DISK"
echo ""

mapfile -t PARTS < <(lsblk -lnpo NAME "$DISK" | grep -v "^${DISK}$")

echo -e "${BOLD}Install options:${NC}"
echo -e "  ${GREEN}1)${NC} Use ENTIRE disk (wipes everything)"
echo -e "  ${GREEN}2)${NC} Use free/unallocated space (dual-boot safe)"
[ ${#PARTS[@]} -gt 0 ] && echo -e "  ${GREEN}3)${NC} Replace an existing partition"
echo ""

read -rp "Choice: " INSTALL_MODE

EFI_PART=""
ROOT_PART=""

part_suffix() {
    [[ "$1" == *nvme* ]] || [[ "$1" == *mmcblk* ]] && echo "p" || echo ""
}

case "$INSTALL_MODE" in
1)
    warn "This will ERASE ALL DATA on $DISK"
    read -rp "Type 'yes' to confirm: " CONFIRM
    [ "$CONFIRM" = "yes" ] || die "Aborted"

    info "Partitioning $DISK..."
    wipefs -af "$DISK" &>/dev/null
    parted -s "$DISK" mklabel gpt
    parted -s "$DISK" mkpart "EFI" fat32 1MiB 513MiB
    parted -s "$DISK" set 1 esp on
    parted -s "$DISK" mkpart "LEOS" btrfs 513MiB 100%
    settle

    S=$(part_suffix "$DISK")
    EFI_PART="${DISK}${S}1"
    ROOT_PART="${DISK}${S}2"
    mkfs.fat -F32 "$EFI_PART"
    ;;
2)
    # Find largest free region using parted's machine-readable output
    # Format: num:start:end:size:fs:name:flags; (free space has "free" in fs field)
    LARGEST_FREE=""
    LARGEST_SIZE=0
    while IFS=':' read -r num start end size fs rest; do
        [[ "$fs" == "free;" ]] || [[ "$fs" == "free" ]] || continue
        size_num=${size//MiB/}
        size_int=${size_num%%.*}
        if [ "${size_int:-0}" -gt "$LARGEST_SIZE" ] 2>/dev/null; then
            LARGEST_SIZE=$size_int
            LARGEST_FREE="$size_int ${start} ${end}"
        fi
    done < <(parted -s -m "$DISK" unit MiB print free 2>/dev/null | tail -n +3)
    [ -n "$LARGEST_FREE" ] || die "No free space found on $DISK. Shrink a partition from Windows first."

    FREE_SIZE_MB=$(echo "$LARGEST_FREE" | awk '{print $1}')
    FREE_START=$(echo "$LARGEST_FREE" | awk '{print $2}')
    FREE_END=$(echo "$LARGEST_FREE" | awk '{print $3}')
    [ "$FREE_SIZE_MB" -gt 10240 ] || die "Need at least 10GB free (found ${FREE_SIZE_MB}MiB)"

    info "Using free space: $FREE_START → $FREE_END (${FREE_SIZE_MB} MiB)"

    EFI_EXISTING=$(blkid -t PART_ENTRY_TYPE="c12a7328-f81f-11d2-ba4b-00a0c93ec93b" -o device 2>/dev/null | grep "$DISK" | head -1) || true

    if [ -n "$EFI_EXISTING" ]; then
        ok "Found existing EFI partition: $EFI_EXISTING"
        EFI_PART="$EFI_EXISTING"
        parted -s "$DISK" mkpart "LEOS" btrfs "$FREE_START" "$FREE_END"
        settle
        ROOT_PART=$(lsblk -npo NAME "$DISK" | grep -v "^${DISK}$" | tail -1)
    else
        FREE_START_NUM=${FREE_START//MiB/}
        EFI_END_NUM=$((FREE_START_NUM + 512))
        parted -s "$DISK" mkpart "EFI" fat32 "${FREE_START}" "${EFI_END_NUM}MiB"
        settle
        EFI_PART=$(lsblk -npo NAME "$DISK" | grep -v "^${DISK}$" | tail -1)
        EFI_PARTNUM=$(cat "/sys/class/block/$(basename "$EFI_PART")/partition")
        parted -s "$DISK" set "$EFI_PARTNUM" esp on
        parted -s "$DISK" mkpart "LEOS" btrfs "${EFI_END_NUM}MiB" "$FREE_END"
        settle
        ROOT_PART=$(lsblk -npo NAME "$DISK" | grep -v "^${DISK}$" | tail -1)
        mkfs.fat -F32 "$EFI_PART"
    fi
    ;;
3)
    [ ${#PARTS[@]} -gt 0 ] || die "No partitions to replace"
    EFI_EXISTING=$(blkid -t PART_ENTRY_TYPE="c12a7328-f81f-11d2-ba4b-00a0c93ec93b" -o device 2>/dev/null | grep "$DISK" | head -1) || true

    REPLACEABLE=()
    for p in "${PARTS[@]}"; do
        [ "$p" = "$EFI_EXISTING" ] && continue
        REPLACEABLE+=("$p")
    done
    [ ${#REPLACEABLE[@]} -gt 0 ] || die "No replaceable partitions"

    echo -e "${BOLD}Select partition to replace:${NC}"
    for i in "${!REPLACEABLE[@]}"; do
        p="${REPLACEABLE[$i]}"
        echo -e "  ${GREEN}$((i+1)))${NC} $p  $(lsblk -no SIZE "$p" | xargs)  $(lsblk -no FSTYPE "$p" | xargs)"
    done
    read -rp "Partition: " PART_NUM
    [[ "$PART_NUM" =~ ^[0-9]+$ ]] && [ "$PART_NUM" -ge 1 ] && [ "$PART_NUM" -le ${#REPLACEABLE[@]} ] || die "Invalid"

    ROOT_PART="${REPLACEABLE[$((PART_NUM-1))]}"
    warn "Will FORMAT: $ROOT_PART ($(lsblk -no SIZE "$ROOT_PART" | xargs))"
    read -rp "Type 'yes' to confirm: " CONFIRM
    [ "$CONFIRM" = "yes" ] || die "Aborted"

    [ -n "$EFI_EXISTING" ] || die "No EFI partition found"
    EFI_PART="$EFI_EXISTING"
    ;;
*)
    die "Invalid choice"
    ;;
esac

[ -b "$ROOT_PART" ] || die "Root partition $ROOT_PART not found"
[ -b "$EFI_PART" ] || die "EFI partition $EFI_PART not found"

# ═══════════════════════════════════════════
# DUAL-BOOT SAFETY CHECKS
# ═══════════════════════════════════════════
HAS_WINDOWS=false

# Detect Windows on this disk (NTFS partitions)
if lsblk -no FSTYPE "$DISK" 2>/dev/null | grep -qi "ntfs"; then
    HAS_WINDOWS=true
fi

# Probe EFI for Windows boot files
TMPCHECK=$(mktemp -d)
if mount -o ro "$EFI_PART" "$TMPCHECK" 2>/dev/null; then
    if [ -f "$TMPCHECK/EFI/Microsoft/Boot/bootmgfw.efi" ]; then
        HAS_WINDOWS=true
    fi
    umount "$TMPCHECK" 2>/dev/null || true
fi
rmdir "$TMPCHECK" 2>/dev/null || true

if [ "$HAS_WINDOWS" = true ]; then
    warn "Windows detected on this disk — applying dual-boot safety mode"
    echo ""
    echo -e "${YELLOW}IMPORTANT: Before continuing, ensure:${NC}"
    echo "  1. Windows Fast Startup is DISABLED (Power Options → Choose what power buttons do)"
    echo "  2. Windows is FULLY shut down (not hibernated) — Shift+Shutdown, not just Shutdown"
    echo "  3. BitLocker is disabled or you have your recovery key"
    echo ""

    # Check FAT32 dirty bit on EFI partition
    if command -v fsck.fat &>/dev/null; then
        if ! fsck.fat -n "$EFI_PART" &>/dev/null; then
            warn "EFI partition appears DIRTY (Fast Startup or unclean Windows shutdown)"
            warn "Mounting and writing to it now risks corrupting Windows boot files"
            read -rp "Continue anyway? Type 'yes' to proceed: " DIRTY_OK
            [ "$DIRTY_OK" = "yes" ] || die "Aborted — boot Windows, fully shut down, then retry"
        fi
    fi

    read -rp "Continue with dual-boot install? [y/N]: " DUAL_OK
    [[ "$DUAL_OK" =~ ^[Yy]$ ]] || die "Aborted by user"
fi

# ═══════════════════════════════════════════
# TIMEZONE
# ═══════════════════════════════════════════
echo ""
info "Timezone setup"
DETECTED_TZ=$(curl -s http://ip-api.com/line?fields=timezone 2>/dev/null || echo "")
if [ -n "$DETECTED_TZ" ] && [ -f "/usr/share/zoneinfo/$DETECTED_TZ" ]; then
    read -rp "Detected timezone: $DETECTED_TZ — use it? [Y/n]: " TZ_CONFIRM
    [[ "$TZ_CONFIRM" =~ ^[Nn] ]] && read -rp "Enter timezone: " TIMEZONE || TIMEZONE="$DETECTED_TZ"
else
    read -rp "Enter timezone (e.g. Asia/Kolkata): " TIMEZONE
fi
[ -f "/usr/share/zoneinfo/$TIMEZONE" ] || die "Invalid timezone: $TIMEZONE"

# ═══════════════════════════════════════════
# FORMAT + BTRFS SUBVOLUMES
# ═══════════════════════════════════════════
echo ""
info "Creating btrfs filesystem on $ROOT_PART..."
mkfs.btrfs -f -L LEOS "$ROOT_PART" || die "Failed to create btrfs filesystem"

info "Creating subvolumes..."
mount "$ROOT_PART" /mnt || die "Failed to mount $ROOT_PART"
btrfs subvolume create /mnt/@ || die "Failed to create @ subvolume"
btrfs subvolume create /mnt/@home || die "Failed to create @home subvolume"
btrfs subvolume create /mnt/@swap || die "Failed to create @swap subvolume"
btrfs subvolume create /mnt/@models || die "Failed to create @models subvolume"
btrfs subvolume create /mnt/@snapshots || die "Failed to create @snapshots subvolume"
umount /mnt

# Mount with compression
BTRFS_OPTS="compress=zstd:3,ssd,noatime,space_cache=v2"
mount -o "$BTRFS_OPTS,subvol=@" "$ROOT_PART" /mnt
mkdir -p /mnt/{home,swap,opt/models,.snapshots,boot}
mount -o "$BTRFS_OPTS,subvol=@home" "$ROOT_PART" /mnt/home
mount -o "noatime,ssd,space_cache=v2,subvol=@swap" "$ROOT_PART" /mnt/swap
chattr +C /mnt/swap 2>/dev/null || true
mount -o "compress=no,ssd,noatime,space_cache=v2,subvol=@models" "$ROOT_PART" /mnt/opt/models
mount -o "$BTRFS_OPTS,subvol=@snapshots" "$ROOT_PART" /mnt/.snapshots
mount "$EFI_PART" /mnt/boot

ok "Mounted all subvolumes"

# Backup any existing fallback bootloader before bootctl install overwrites it
if [ "$HAS_WINDOWS" = true ] && [ -f /mnt/boot/EFI/BOOT/BOOTX64.EFI ]; then
    info "Backing up existing /EFI/BOOT/BOOTX64.EFI to BOOTX64.EFI.bak"
    cp /mnt/boot/EFI/BOOT/BOOTX64.EFI /mnt/boot/EFI/BOOT/BOOTX64.EFI.bak
fi
# Backup Windows boot files (defense in depth — bootctl shouldn't touch these but just in case)
if [ "$HAS_WINDOWS" = true ] && [ -d /mnt/boot/EFI/Microsoft ]; then
    info "Verifying Windows boot files present and creating backup manifest"
    find /mnt/boot/EFI/Microsoft -type f | sort > /mnt/boot/.leos-windows-files.bak.txt 2>/dev/null || true
fi

# ═══════════════════════════════════════════
# PACSTRAP
# ═══════════════════════════════════════════
info "Installing base system..."
pacstrap -K /mnt base linux linux-firmware btrfs-progs networkmanager sudo nano git || die "pacstrap failed — check internet connection"

# ═══════════════════════════════════════════
# FSTAB
# ═══════════════════════════════════════════
info "Generating fstab..."
genfstab -U /mnt > /mnt/etc/fstab

# ═══════════════════════════════════════════
# COPY LEOS INTO NEW SYSTEM
# ═══════════════════════════════════════════
info "Copying LEOS config into new system..."
cp -r "$LEOS_DIR" /mnt/root/LEOS

# ═══════════════════════════════════════════
# CHROOT SETUP
# ═══════════════════════════════════════════
info "Configuring system..."

cat > /mnt/root/leos-setup.sh << CHROOT_EOF
#!/bin/bash

# Timezone + locale
ln -sf /usr/share/zoneinfo/$TIMEZONE /etc/localtime
# Use local time if Windows is on this system (Windows expects RTC=local by default)
if [ "$HAS_WINDOWS" = "true" ]; then
    hwclock --systohc --localtime
    timedatectl set-local-rtc 1 --adjust-system-clock 2>/dev/null || true
else
    hwclock --systohc
fi
echo "en_US.UTF-8 UTF-8" > /etc/locale.gen
locale-gen
echo "LANG=en_US.UTF-8" > /etc/locale.conf
echo "leos" > /etc/hostname
cat > /etc/hosts << 'HOSTS'
127.0.0.1   localhost
::1         localhost
127.0.1.1   leos.localdomain leos
HOSTS

# Deploy LEOS mkinitcpio config
cp /root/LEOS/system/mkinitcpio.conf /etc/mkinitcpio.conf
mkinitcpio -P || { echo "mkinitcpio failed!"; exit 1; }

# Bootloader (systemd-boot)
bootctl install || { echo "bootctl failed!"; exit 1; }
ROOT_UUID=\$(blkid -s UUID -o value "$ROOT_PART")

cat > /boot/loader/loader.conf << 'LOADER'
default leos.conf
timeout 3
console-mode max
LOADER

# Boot entry — uses stock kernel initially, linux-leos after kernel build
cat > /boot/loader/entries/leos.conf << ENTRY
title   LEOS
linux   /vmlinuz-linux
initrd  /initramfs-linux.img
options root=UUID=\$ROOT_UUID rootflags=subvol=@ rw zswap.enabled=1 zswap.compressor=zstd zswap.zpool=zsmalloc zswap.max_pool_percent=50
ENTRY

# Run full LEOS system setup (non-fatal — system is bootable even if this fails)
chmod +x /root/LEOS/scripts/install.sh
/root/LEOS/scripts/install.sh || echo "WARNING: install.sh had errors, but system is bootable. Re-run after reboot."

rm -f /root/leos-setup.sh
CHROOT_EOF

chmod +x /mnt/root/leos-setup.sh
arch-chroot /mnt /root/leos-setup.sh

# ═══════════════════════════════════════════
# DONE
# ═══════════════════════════════════════════
# Robust unmount: sync, kill stragglers, retry, lazy fallback
# Critical for shared EFI partition — must be cleanly unmounted to avoid FAT32 dirty bit
info "Syncing and unmounting..."
sync
sleep 1

# Kill any process still using /mnt (rare but happens with pacstrap leftovers)
fuser -km /mnt 2>/dev/null || true
sleep 1

# Try clean unmount first
if ! umount -R /mnt 2>/dev/null; then
    warn "Unmount busy — retrying..."
    sleep 2
    sync
    if ! umount -R /mnt 2>/dev/null; then
        warn "Still busy — using lazy unmount (kernel will detach when free)"
        umount -lR /mnt || die "Unmount failed completely. Run 'sync; umount -R /mnt' manually before reboot."
    fi
fi
sync
ok "All filesystems unmounted cleanly"

echo ""
echo -e "${GREEN}${BOLD}"
echo "╔══════════════════════════════════════════╗"
echo "║       LEOS Installation Complete!        ║"
echo "╠══════════════════════════════════════════╣"
echo "║  Login:     leos / leos                  ║"
echo "║  Desktop:   Hyprland (Super+Enter=term)  ║"
echo "║                                          ║"
echo "║  After reboot, build custom kernel:      ║"
echo "║    cd ~/LEOS/kernel && makepkg -s        ║"
echo "║    sudo pacman -U linux-leos-*.pkg.tar.zst║"
echo "║    sudo mkinitcpio -P && sudo reboot     ║"
echo "║                                          ║"
echo "║  Remove USB and reboot now!              ║"
echo "╚══════════════════════════════════════════╝"
echo -e "${NC}"

if [ "$HAS_WINDOWS" = true ]; then
    echo -e "${YELLOW}${BOLD}Dual-boot notes:${NC}"
    echo "  • systemd-boot will show both LEOS and Windows at boot"
    echo "  • If Windows missing: hold firmware boot key (F2/F12/ESC) → Windows Boot Manager"
    echo "  • Backup of original /EFI/BOOT/BOOTX64.EFI saved as BOOTX64.EFI.bak"
    echo "  • RTC set to LOCAL time for Windows compatibility"
    echo ""
fi

read -rp "Reboot now? [Y/n]: " REBOOT
[[ "$REBOOT" =~ ^[Nn] ]] || reboot
