# LEOS Kernel Config Overrides
# Applied ON TOP of full Arch Linux kernel config
# This ensures all hardware drivers are present while adding LEOS optimizations
#
# Usage: PKGBUILD downloads Arch stock config, then applies these overrides

# === Memory Compression (zswap) ===
CONFIG_SWAP=y
CONFIG_ZSWAP=y
CONFIG_ZSWAP_DEFAULT_ON=y
CONFIG_ZSWAP_SHRINKER_DEFAULT_ON=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT="zstd"
CONFIG_ZSWAP_ZPOOL_DEFAULT="zsmalloc"
CONFIG_ZSWAP_MAX_POOL_PERCENT=50

# === zram (backup / embedded use) ===
CONFIG_ZRAM=m
CONFIG_ZRAM_MULTI_COMP=y
CONFIG_ZRAM_WRITEBACK=y
CONFIG_ZRAM_TRACK_ENTRY_ACTIME=y

# === Compression Algorithms ===
CONFIG_CRYPTO_LZ4=y
CONFIG_CRYPTO_LZ4HC=y
CONFIG_CRYPTO_ZSTD=y
CONFIG_CRYPTO_LZO=y
CONFIG_CRYPTO_842=y

# === Memory Allocators ===
CONFIG_ZSMALLOC=y
CONFIG_ZPOOL=y

# === Btrfs Filesystem ===
CONFIG_BTRFS_FS=y
CONFIG_BTRFS_FS_POSIX_ACL=y
CONFIG_BTRFS_FS_CHECK_INTEGRITY=y

# === Cgroups (for AI workload isolation) ===
CONFIG_CGROUPS=y
CONFIG_MEMCG=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_BPF=y

# === Performance ===
CONFIG_PREEMPT=y
CONFIG_HZ_1000=y
CONFIG_NO_HZ_FULL=y
CONFIG_TRANSPARENT_HUGEPAGE=y
CONFIG_TRANSPARENT_HUGEPAGE_ALWAYS=y

# === Disable unnecessary (saves build time) ===
# CONFIG_DEBUG_INFO_BTF is not set
